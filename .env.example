# Supabase (free tier) — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional, server-only: lets /api/ratings write the shared ratings_cache.
# Without it, rating lookups still work — they just aren't cached in the DB.
SUPABASE_SERVICE_ROLE_KEY=

# Podcast Index (free key, server-side only — used from M1)
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# Listen Notes (free tier key, server-side only). Adds the Listen Score
# popularity signal to Top Picks / similar ranking. Header: X-ListenAPI-Key.
LISTEN_NOTES_API_KEY=

# 小宇宙 (Xiaoyuzhou) app-API tokens, server-side only. Optional — adds
# subscriber/play/comment buzz. Obtain via an ultrazg/xyz deployment (SMS
# login). The access token is short-lived; the refresh token renews it.
XIAOYUZHOU_ACCESS_TOKEN=
XIAOYUZHOU_REFRESH_TOKEN=
